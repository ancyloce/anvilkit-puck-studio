{
  "name": "@anvilkit/puck-studio",
  "version": "0.4.4",
  "description": "Shadcn UI replacement for all Puck Editor override surfaces",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./legacy": {
      "types": "./dist/legacy.d.ts",
      "import": "./dist/legacy.js",
      "require": "./dist/legacy.cjs"
    },
    "./overrides": {
      "types": "./dist/overrides.d.ts",
      "import": "./dist/overrides.js",
      "require": "./dist/overrides.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsup && node scripts/build-styles.mjs && node scripts/link-package-styles.mjs && node scripts/validate-package-exports.mjs",
    "dev": "next dev",
    "lint": "tsc --noEmit && eslint src",
    "lint:types": "tsc --noEmit",
    "release": "npx -y -p node@24.10.0 -c 'node ./node_modules/semantic-release/bin/semantic-release.js'",
    "release:dry": "npx -y -p node@24.10.0 -c 'node ./node_modules/semantic-release/bin/semantic-release.js --dry-run --no-ci'",
    "test": "vitest --run",
    "test:types": "tsd"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.3.0",
    "@puckeditor/core": "^0.21.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.19",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "optionalDependencies": {
    "@puckeditor/plugin-ai": "^0.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@puckeditor/core": "0.21.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "next": "^16.2.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semantic-release": "^25.0.3",
    "shadcn": "^4.1.0",
    "tailwindcss": "^4.2.2",
    "tsd": "^0.33.0",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "tsd": {
    "directory": "src/types",
    "compilerOptions": {
      "strict": true,
      "paths": {
        "@anvilkit/puck-studio": [
          "./index.ts"
        ],
        "@/*": [
          "./src/*"
        ]
      }
    }
  }
}
